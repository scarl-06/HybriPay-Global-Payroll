# 🚀 HybriPay Environment Configuration (Template)
# Copy this file to .env and fill in the values.

# --- SERVER CONFIG ---
PORT=4000
DATABASE_URL="postgresql://user:password@localhost:5432/hybripay"
JWT_SECRET="generate-a-secure-random-string"
API_KEY="your-internal-api-key"

# --- SOLANA CONFIG ---
SOLANA_RPC_URL="https://api.devnet.solana.com"
USDC_MINT_ADDRESS="4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU" # Devnet USDC
TREASURY_PRIVATE_KEY="[YOUR_PRIVATE_KEY_ARRAY]" # e.g. [1,2,3...]

# --- ORACLE CONFIG (PYTH) ---
PYTH_HERMES_URL="https://hermes.pyth.network"

# --- WEBHOOK CONFIG ---
WEBHOOK_SECRET="your-webhook-signing-secret"

# --- FRONTEND CONFIG (NEXT.JS) ---
# For local dev: http://localhost:4000/api/v1
# For production: https://your-api.onrender.com/api/v1
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# --- DEMO MODE ---
TREASURY_DEMO_MODE=true # Set to false for real Devnet transactions
